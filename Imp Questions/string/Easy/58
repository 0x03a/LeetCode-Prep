class Solution {
public:
    int lengthOfLastWord(string s) {
       int size=s.length ();
       int i=s.length()-1;
       while(i>=0)
       {
        if(s[i] == ' ')
            i--;
        else
           break;
       }
       int res=0;
       while(i >=0 )
       {
            if(s[i]!=' ')
               res++;
            else 
            break;
        
         i--;
               
       }

       return res;
    }
};
